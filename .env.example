# ── Anthropic (obavezno) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Opciono override (default-i u app/config.py):
# CHAT_MODEL=claude-haiku-4-5-20251001
# EMAIL_MODEL=claude-sonnet-4-6

# ── TTS glas (edge-tts, besplatno) ───────────────────────────
# Opcije: bs-BA-VesnaNeural, bs-BA-GoranNeural, hr-HR-GabrijelaNeural
#         sr-RS-SophieNeural, sr-RS-NicholasNeural, hr-HR-SreckoNeural
# TTS_VOICE=bs-BA-VesnaNeural

# ── Groq Whisper STT (opcionalno, besplatno 7200s/dan) ───────
# Registracija: https://console.groq.com → API Keys → Create
# GROQ_API_KEY=gsk_...

# ── ElevenLabs (opcionalno, plaća se) ────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=

# ── IMAP / SMTP (rezerva ako n8n cloud zataji) ───────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Webshop ──────────────────────────────────────────────────
WEBSHOP_BASE_URL=https://webshop.bitlab.rs
PRODUCT_URL_TEMPLATE=https://webshop.bitlab.rs/proizvod/{urlhash}

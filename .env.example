# ── Anthropic (obavezno) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Opciono override po kanalu (default-i u app/config.py).
# Voice kanal koristi CHAT_MODEL + CHAT_MODEL_EFFORT (dijeli sa chat).
#   EFFORT: low (thinking off, default) | medium (1024 budget) | high (4096 budget)
# CHAT_MODEL=claude-haiku-4-5-20251001
# CHAT_MODEL_EFFORT=low
# EMAIL_MODEL=claude-sonnet-4-6
# EMAIL_MODEL_EFFORT=low

# ── LLM backend selector ─────────────────────────────────────
# "anthropic" (default, produkcija) ili "pwr" (rutira kroz PlaywrightRouter).
# Za vraćanje na Anthropic, samo zakomentariši LLM_BACKEND red ili stavi anthropic.
LLM_BACKEND=pwr
PWR_API_KEY=pwr_...
PWR_BASE_URL=http://127.0.0.1:8765/v1

# Opciono PWR override po kanalu (default-i u app/config.py).
# Eksplicitni model ID (ne alias) — vidi playwright-router/docs/models-and-efforts.md §4.1
# za podržane vrijednosti (claude-sonnet-4-6 / claude-opus-4-7 / claude-haiku-4-5-20251001).
#   EFFORT: low (default) | medium | high — mapira se na reasoning_effort.
# PWR_CHAT_MODEL=claude-sonnet-4-6
# PWR_CHAT_MODEL_EFFORT=low
# PWR_EMAIL_MODEL=claude-sonnet-4-6
# PWR_EMAIL_MODEL_EFFORT=low

# ── TTS glas (edge-tts, besplatno) ───────────────────────────
# Opcije: bs-BA-VesnaNeural, bs-BA-GoranNeural, hr-HR-GabrijelaNeural
#         sr-RS-SophieNeural,
TTS_VOICE=hr-HR-GabrijelaNeural
TTS_RATE=0%

# ── Azure Speech Services (TTS + STT — preferirano za bs/hr/sr) ──
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=northeurope
AZURE_STT_LANGUAGE=hr-HR

# ── Groq Whisper STT (fallback, besplatno 7200s/dan) ─────────
GROQ_API_KEY=gsk_..

# ── IMAP / SMTP (rezerva ako n8n cloud zataji) ───────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Webshop ──────────────────────────────────────────────────
WEBSHOP_BASE_URL=https://webshop.bitlab.rs
PRODUCT_URL_TEMPLATE=https://webshop.bitlab.rs/{urlhash}.html

DASHBOARD_API_KEY=eCVylDhsSbMeivD2xe6g-XZg605WsVRSXko0dHHA23I

# ── Eval/diagnostic override (NIKAD ne uključuj u produkciji) ──
# Kad je setovan, handle_search_products ignoriše `top_k` koji Claude
# šalje i koristi ovu vrijednost. Cilj: eval skripte mogu da vide pun
# RAG pool (ne Claude-ov samostalni izbor od 5-10 proizvoda).
# Vrijednost 5287 = ukupan broj proizvoda u indeksu (efektivno: vrati sve
# što filteri propuste). Pošto chat widget tada dobija thousands of
# products po upitu, NE OSTAVLJAJ ovo uključeno trajno.
# SEARCH_TOP_K_OVERRIDE=5287

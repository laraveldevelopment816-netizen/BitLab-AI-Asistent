# ── Anthropic (obavezno) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Opciono override (default-i u app/config.py):
# CHAT_MODEL=claude-haiku-4-5-20251001
# EMAIL_MODEL=claude-sonnet-4-6

# ── TTS glas (edge-tts, besplatno) ───────────────────────────
# Opcije: bs-BA-VesnaNeural, bs-BA-GoranNeural, hr-HR-GabrijelaNeural
#         sr-RS-SophieNeural,
TTS_VOICE=hr-HR-GabrijelaNeural
TTS_RATE=0%

# ── Azure Speech Services (TTS + STT — preferirano za bs/hr/sr) ──
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=northeurope
AZURE_STT_LANGUAGE=hr-HR

# ── Groq Whisper STT (fallback, besplatno 7200s/dan) ─────────
GROQ_API_KEY=gsk_..

# ── IMAP / SMTP (rezerva ako n8n cloud zataji) ───────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Webshop ──────────────────────────────────────────────────
WEBSHOP_BASE_URL=https://webshop.bitlab.rs
PRODUCT_URL_TEMPLATE=https://webshop.bitlab.rs/{urlhash}.html

DASHBOARD_API_KEY=eCVylDhsSbMeivD2xe6g-XZg605WsVRSXko0dHHA23I

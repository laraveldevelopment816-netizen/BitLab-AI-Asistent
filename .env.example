# ── Anthropic (obavezno) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Opciono override (default-i u app/config.py):
# CHAT_MODEL=claude-haiku-4-5-20251001
# EMAIL_MODEL=claude-sonnet-4-6

# ── TTS glas (edge-tts, besplatno) ───────────────────────────
# Opcije: bs-BA-VesnaNeural, bs-BA-GoranNeural, hr-HR-GabrijelaNeural
#         sr-RS-SophieNeural, sr-RS-NicholasNeural, hr-HR-SreckoNeural
# TTS_VOICE=bs-BA-VesnaNeural

# ── Azure Speech Services (preporučeno: TTS + STT, jedan ključ) ──
# Najbolji kvalitet i pokrivenost za bs/hr/sr (Vesna, Gabrijela, Sophie...).
# Free tier (uvijek besplatno): 500K znakova/mjesec Neural TTS + 5h/mjesec STT.
# Setup:
#   1. portal.azure.com → "Create resource" → "Speech Services" (Free F0 tier)
#   2. Kopiraj Key 1 i Region (npr. "westeurope")
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=westeurope
# AZURE_STT_LANGUAGE=hr-HR

# ── Groq Whisper STT (opcionalno, besplatno 7200s/dan) ───────
# Fallback ako Azure ključ nije postavljen.
# Registracija: https://console.groq.com → API Keys → Create
# GROQ_API_KEY=gsk_...

# ── IMAP / SMTP (rezerva ako n8n cloud zataji) ───────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Webshop ──────────────────────────────────────────────────
WEBSHOP_BASE_URL=https://webshop.bitlab.rs
PRODUCT_URL_TEMPLATE=https://webshop.bitlab.rs/proizvod/{urlhash}

# ── Dashboard / logging (Sesija 8) ───────────────────────────
# Bearer token za /api/dashboard/*. Generiši:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# DASHBOARD_API_KEY=

# Opcioni override default DB putanje (default: var/bitlab.db)
# DASHBOARD_DB_URL=sqlite+aiosqlite:///var/bitlab.db

# Source ovaj fajl prije pokretanja deploy.sh:
#   scp deploy/prod.env.example ai@aiasistent.bitlab.rs:~/aiasistent-prod.env
#   ssh ai@aiasistent.bitlab.rs
#   source ~/aiasistent-prod.env
#   bash ~/deploy.sh setup-domain   # prvi put
#   bash ~/deploy.sh release        # svaki sledeći

export PROJECT_NAME="aiasistent-prod"
export DOMAIN="aiasistent.bitlab.rs"
export PORT="8000"
export BRANCH="main"
export REPO_URL="git@github.com:laraveldevelopment816-netizen/BitLab-AI-Asistent.git"
export ENTRY_POINT="app.main:app"
export ADMIN_EMAIL="admin@bitlab.rs"
export ENV_TEMPLATE="/home/ai/aiasistent-staging/shared/.env"

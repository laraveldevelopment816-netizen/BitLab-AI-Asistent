# Source ovaj fajl prije pokretanja deploy.sh za staging:
#   scp deploy/staging.env.example ai@aiasistent.bitlab.rs:~/aiasistent-staging.env
#   ssh ai@aiasistent.bitlab.rs
#   source ~/aiasistent-staging.env
#   bash ~/deploy.sh release        # staging je već postavljen, samo release-ujemo

export PROJECT_NAME="aiasistent-staging"
export DOMAIN="staging.aiasistent.bitlab.rs"
export PORT="8001"
export BRANCH="staging"
export REPO_URL="git@github.com:laraveldevelopment816-netizen/BitLab-AI-Asistent.git"

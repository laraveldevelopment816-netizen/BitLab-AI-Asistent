# bitlab-ai-asistent via OpenClaw gateway (REQUIRES code change)
#
# Status: NOT YET WIRED — current code uses Anthropic SDK with tool_use directly.
# Switching to OpenClaw means switching from anthropic.Anthropic to openai.OpenAI
# pointing at /v1/chat/completions. Tool definitions need OpenAI-format conversion
# (functions array vs Anthropic's tools array).
#
# This is a substantial refactor (~2-4h) — keep direct Anthropic API as default
# until refactor is done, then flip USE_OPENCLAW=true.

# When implemented, set:
USE_OPENCLAW=true
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_API_KEY=cfcc8bc346a6ca846c6d686a4b5d64fb40d0f66908205cf3
OPENCLAW_MODEL=openclaw/default

# Existing Anthropic key still required as fallback when USE_OPENCLAW=false:
ANTHROPIC_API_KEY=sk-ant-...

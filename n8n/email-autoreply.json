{
  "name": "BitLab Email Auto-Reply",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "includeSpamTrash": false
        },
        "options": {
          "simple": false
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail-oauth-creds",
          "name": "BitLab Gmail OAuth"
        }
      },
      "notes": "Polja: $json.Subject, $json.From, $json.Text"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "upit" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "ponuda" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "cijen" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "dostava" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "garancija" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "kako" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "imate li" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "trebam" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "kupiti" },
            { "value1": "={{ $json.Subject.toLowerCase() }}", "operation": "contains", "value2": "narudžba" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "upit" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "ponuda" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "cijen" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "dostava" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "garancija" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "kako" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "imate li" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "trebam" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "kupiti" },
            { "value1": "={{ $json.snippet.toLowerCase() }}", "operation": "contains", "value2": "narudžba" }
          ]
        },
        "combineOperation": "any"
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "IF: Relevantna tema",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300],
      "notes": "Propušta ako subject ili snippet sadrži bilo koji od ključnih pojmova."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://bonsai-census-daisy.ngrok-free.dev/api/email",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            { "name": "sender", "value": "={{ $json.From }}" },
            { "name": "subject", "value": "={{ $json.Subject }}" },
            { "name": "body", "value": "={{ $json.snippet }}" }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "HTTP: Pitaj AI Asistenta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 200],
      "notes": "Šalje sender, subject, body (snippet) kao JSON. Vraća { reply, escalated, tools_used }."
    },
    {
      "parameters": {
        "jsCode": "const reply = $input.item.json.reply || '';\n\nconst html = reply\n  .split('\\n\\n')\n  .map(para => {\n    const escaped = para\n      .replace(/&/g, '&amp;')\n      .replace(/</g, '&lt;')\n      .replace(/>/g, '&gt;');\n    return '<p>' + escaped.replace(/\\n/g, '<br>') + '</p>';\n  })\n  .join('\\n');\n\nreturn [{ json: { ...$input.item.json, replyHtml: html } }];"
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Format: Text u HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 200],
      "notes": "Konvertuje \\n\\n → <p>, \\n → <br>. Escapuje HTML znakove."
    },
    {
      "parameters": {
        "sendTo": "={{ $('Gmail Trigger').item.json.From }}",
        "subject": "=Re: {{ $('Gmail Trigger').item.json.Subject }}",
        "emailType": "html",
        "message": "={{ $json.replyHtml }}",
        "options": {}
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Gmail: Pošalji AI Reply",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1120, 200],
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail-oauth-creds",
          "name": "BitLab Gmail OAuth"
        }
      },
      "notes": "emailType: html → šalje HTML email. message = replyHtml iz prethodnog Code noda."
    },
    {
      "parameters": {},
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Preskoči (nerelevantno)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [680, 400]
    }
  ],

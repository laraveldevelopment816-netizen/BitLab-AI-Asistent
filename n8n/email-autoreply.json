  "_setup_instructions": {
    "koraci": [
      "1. n8n cloud: app.n8n.cloud → New Workflow → Import from JSON → ovaj fajl",
      "2. Credentials > New > Gmail OAuth2 → klikni 'Sign in with Google'",
      "3. Pokrenuti lokalni server: uvicorn app.main:app --reload",
      "4. Pokrenuti ngrok: ~/bin/ngrok http 8000",
      "5. Activate workflow (toggle gornji desni ugao)",
      "6. Test: pošalji email na Gmail adresu sa subject koji sadrži 'upit', 'ponuda', 'cijen' itd."
    ],
    "polja_gmail_triggera": {
      "subject": "$json.Subject",
      "posiljalac": "$json.From",
      "snippet": "$json.snippet"
    }
